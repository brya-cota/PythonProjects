# Create a function called calculate_love_score() that determines the compatibility between two names based on
# the occurrence of letters in "TRUE" and "LOVE"
# 1. Take both people's names and check for the number of times the letters in the word TRUE occurs.
# 2. Then check for the number of times the letters in the word LOVE occurs.
# 3. Then combine these numbers to make a 2 digit number and print it out.

def calculate_love_score(name1, name2):
    combined_names = (name1 + name2).lower()
    
    #checking for 'TRUE' values
    t = combined_names.count("t")
    r = combined_names.count("r")
    u = combined_names.count("u")
    e = combined_names.count("e")
    true_value = t + r + u + e
    
    #checking for 'LOVE' values
    l = combined_names.count("l")
    o = combined_names.count("o")
    v = combined_names.count("v")
    e = combined_names.count("e")
    love_value = l + o + v + e
    
    #turning integer values into string to concatinate them
    str_true_value = str(true_value)
    str_love_value = str(love_value)
    #true_love_total = int(str(true_value) + str(love_value))
    
    true_love_total = str_true_value + str_love_value

    print (true_love_total)
    
calculate_love_score("Kim Kardashian", "Kanye West")
