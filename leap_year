def is_leap_year(year):
    int_year = year
    
    if int_year % 400 == 0:
        return True
    
    if int_year % 100 == 0:
        return False

    if int_year % 4 == 0:
        return True
  
    return False

def is_leap_year(year):
    if year % 4 == 0:
        if year % 100 == 0:
            if year % 400 == 0:
                return True
            else:
                return False
        else:
            return True
    else:
        return False
