alphabet = ['a', 'b', 'c', 'd', 'e', 'f', 'g', 'h', 'i', 'j', 'k', 'l', 'm', 'n', 'o', 'p', 'q', 'r', 's', 't', 'u', 'v', 'w', 'x', 'y', 'z']

def caesar(original_text, shift_amount, encode_or_decode):
    output_text = ""
#this if statement will decrypt the text by going backwards in the list. any number multiplied by a negative becomes negative. 
#and will subtract the shift_amount instead of adding it 5+(-3)
    if encode_or_decode == "decode":
        shift_amount *= -1

    for letter in original_text:
#will add any symbols/special characters to the end of the text. spaces will remain in place 
        if letter not in alphabet:
            output_text += letter
        else:
            shifted_position = alphabet.index(letter) + shift_amount
            shifted_position %= len(alphabet) #26
            output_text += alphabet[shifted_position]

    print(f"Here is the {encode_or_decode}d result: {output_text}")


#restaring the cipher program by asking the user if they want to continue
continue_encryption = True

while continue_encryption:
    direction = input("Type 'encode' to encrypt, type 'decode' to decrypt:\n").lower()
    text = input("Type your message:\n").lower()
    shift = int(input("Type the shift number:\n"))

    caesar(original_text=text, shift_amount=shift, encode_or_decode=direction)

    restart = input("Type 'yes' if you want to go again. Otherwise type 'no'.\n").lower()
    if restart == "no":
        continue_encryption = False
        print("Goodbye.")
