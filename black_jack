''' 
This project allows you to play a game of BlackJack with the computer
'''
# Returns random card from the deck
def deal_card():
    cards = [11, 2, 3, 4, 5, 6, 7, 8, 9, 10, 10, 10, 10]
    return random.choice(cards)

# A function that takes a List of cards as input and return the sum of all card w/in the list
def calculate_score(cards):
    # Checking for a black jack (ace + 10, a hand with only 2 cards) and returning a 0 - which will represent a blackjack
    #if 10 in cards and 11 in cards and len(cards) == 2:
    if sum(cards) == 21 and len(cards) == 2:
            return 0
    # Check for an 11 (ace) if the score is already over 21. Remove the 11 and replace it with a 1
    elif 11 in cards and sum(cards) > 21:
        cards.remove(11)
        cards.append(1)
    return sum(cards)

# This function compares the user score and the computer score to determine who wins
def compare(u_score, comp_score):
    if u_score == comp_score:
        return "It's a tie!"
    elif u_score == 0 or comp_score > 21:
        return "You win!"
    elif comp_score == 0 or u_score > 21:
        return "Computer wins!"
    elif u_score > comp_score:
        return "You win!"
    else:
        return "Computer wins!"

def play_game():
# Creating and selecting 2 random cards for the user and computer
    user_cards = []
    computer_cards = []
    user_cards.extend([deal_card(), deal_card()])
    computer_cards.extend([deal_card(), deal_card()])

    user_score = -1
    computer_score = -1
    is_game_over = False

    # If the game hasn't ended, ask the user if they want to draw another card. If yes, add that card to the user_cards. If no, end game.
    # But frist, check if the computer or the user has a blackjack (0) or if the users score is over 21, then the game ends
    while not is_game_over:
        # Summing up the user_score and computer_score then printing users_cards, the sum, and the computers first card
        user_score = calculate_score(user_cards)
        computer_score = calculate_score(computer_cards)
        print(f"Users cards: {user_cards} Current user score: {user_score}")
        print(f"Computers first card: {computer_cards[0]}")
        if user_score == 0 or computer_score == 0 or user_score > 21:
            is_game_over = True
        else:
            draw_another_card = input("Do you want to draw another card? Yes or No. ")
            if draw_another_card == "yes":
                user_cards.append(deal_card())
            else:
                is_game_over = True

    # Let the computer play. The computer should keep drawing cards as long as it has a score less than 17
    while computer_score != 0 and computer_score > 17:
        computer_cards.append(deal_card())
        computer_score = calculate_score(computer_cards)

    # Calling compare() function
    print(compare(user_score, computer_score))

    print(f"Users cards: {user_cards} Current user score: {user_score}")
    print(f"Computers cards: {computer_cards} Current computer score: {computer_score}")

# Asking the user if they want to play a game and clearing the console if they say yes
while input("Do you want to play a game of BlackJack? Yes or No? ") == "yes":
        print("\n" * 20)
        print(art.logo)
        play_game()
