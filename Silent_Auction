#building a blind auction with multiple users and storing the names/bids into a dictionary.

import art
print(art.logo)

highest_bid = 0
winner = ""
bidders = {}
continue_auction = True
while continue_auction:
    user_name = input("What is your name?: ").lower()
    user_bid = int(input("What is your bid?: $ "))
    other_users = input("Are there any other bidders? Type 'yes' or 'no'. ")
    if other_users == 'yes':
            print("\n" * 20) #clearing the screen for new bidder
    elif other_users == "no":
            continue_auction = False
            print(f"The winner is {winner} with a bid of {highest_bid}. ")

    bidders[user_name] = user_bid
    for bids in bidders:
        each_bid = bidders[bids]
        if each_bid > highest_bid:
            highest_bid = each_bid
            winner = bids
